# Copy this file to .env and fill in real values
# Never commit .env to git
# Service: flood-service-crm — Port 4002 (local) / Railway injects PORT

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4002
NODE_ENV=development
# Railway: set NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Database is hosted on Railway (was Neon — migrated 2026-05-19).
# ONE Railway Postgres plugin hosts TWO databases:
#   flood_community  ← sibling service
#   flood_crm        ← this service
#
# Local Docker:  jdbc:postgresql://localhost:5434/flood_crm?user=flood&password=flood
# Railway:       jdbc:postgresql://${PGHOST}:${PGPORT}/flood_crm?user=${PGUSER}&password=${PGPASSWORD}&sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5434/flood_crm?user=flood&password=flood

# ── Railway: SPRING_DATASOURCE_URL takes priority ─────────────────────────────
# Railway's PostgreSQL plugin sets DATABASE_URL as "postgresql://..." (no jdbc:
# prefix, and points at the default `railway` database). Spring Boot needs the
# jdbc: prefix AND the right database name, so override with template syntax:
#   SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/flood_crm?user=${{Postgres.PGUSER}}&password=${{Postgres.PGPASSWORD}}&sslmode=require
# SPRING_DATASOURCE_URL overrides DATABASE_URL in application.yml.
#
# Before first deploy on a fresh Railway Postgres: create the two databases
# and apply manual migrations — see scripts/README.md.
SPRING_DATASOURCE_URL=

# Docker Compose DB credentials (only needed when using docker-compose up locally)
DB_USER=flood
DB_PASSWORD=flood

# ── HikariCP pool size ────────────────────────────────────────────────────────
# Railway Postgres Hobby plan: 100 max connections. Keep at 5 to leave headroom
# for the community service + ad-hoc psql sessions.
HIKARI_MAX_POOL_SIZE=5

# ── Hibernate DDL ─────────────────────────────────────────────────────────────
# Railway: set HIBERNATE_DDL_AUTO=validate once schema is stable.
HIBERNATE_DDL_AUTO=update

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6381
# Railway:      rediss://default:PASSWORD@HOST:PORT  (or the ${{Redis.REDIS_URL}} plugin ref)
# Leave empty to use in-memory cache (no Redis needed for local dev without Docker)
REDIS_URL=redis://localhost:6381
# Production (Railway): set REDIS_URL=${{Redis.REDIS_URL}} so it follows credential rotation

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# ── Ingest API key ─────────────────────────────────────────────────────────────
# Received from flood-service-community when POSTing sensor readings.
# Must match INGEST_API_KEY set in flood-service-community.
INGEST_API_KEY=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Railway: set to your actual frontend Railway domains, e.g.:
#   CORS_ALLOWED_ORIGINS=https://flood-crm.up.railway.app,https://flood-community.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave empty in development — emails are logged to console instead
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
DEV_EMAIL_RECIPIENT=

# ── Admin seed ───────────────────────────────────────────────────────────────
# Initial admin account created on first startup. Change before deploying.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_strong_admin_password
